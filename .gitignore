venv/
env/
.env
.venv/
env.bak/
venv.bak/

# Django
*.log
*.pot
*.pyc
__pycache__/
local_settings.py
db.sqlite3
db.sqlite3-journal

# MySQL / Database dumps
*.sql
*.mysql

# Python packaging
*.py[cod]
*$py.class
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ---- Node.js / React / Vite (Frontend) ----
# Logs
logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# ---- Editor directories and files ----
.vscode/*
!.vscode/extensions.json
.idea
.history/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ---- OS Files ----
.DS_Store
Thumbs.db
